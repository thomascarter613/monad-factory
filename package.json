{
  "name": "monad-factory",
  "version": "0.0.0",
  "private": true,
  "description": "Maximal functional, local-first, polyglot, AI-ready, governance-grade monorepo product-factory platform.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "templates/*"
  ],
  "scripts": {
    "check": "bun run check:foundation && bun run check:toolchain && bun run check:ci && bun run check:github-planning && bun run check:rust && bun run doctor:ci && bun run format:check",
    "check:foundation": "bash scripts/check-foundation.sh",
    "check:toolchain": "bash scripts/check-root-toolchain.sh",
    "doctor": "python3 scripts/doctor.py",
    "format:check": "biome check .",
    "format:write": "biome check --write .",
    "hooks:install": "lefthook install",
    "lint": "biome lint .",
    "moon:check": "moon run repo:check",
    "moon:version": "moon --version",
    "typecheck": "tsc --showConfig --project tsconfig.base.json > /dev/null",
    "check:ci": "bash scripts/check-ci.sh",
    "ci:local": "bun run check:ci && bun run check",
    "check:github-planning": "python3 scripts/github/check-github-planning.py",
    "github:labels": "bash scripts/github/create-labels.sh",
    "github:issues:dry-run": "python3 scripts/github/create-issues.py --dry-run",
    "github:issues": "bash scripts/github/create-issues.sh",
    "doctor:ci": "python3 scripts/doctor.py --ci",
    "doctor:strict": "python3 scripts/doctor.py --strict",
    "check:rust": "bash scripts/check-rust-workspace.sh",
    "rust:check": "cargo check --workspace --all-targets",
    "rust:fmt": "cargo fmt --all",
    "rust:fmt:check": "cargo fmt --all -- --check",
    "rust:clippy": "cargo clippy --workspace --all-targets -- -D warnings",
    "rust:test": "cargo test --workspace --all-targets",
    "monad:help": "cargo run -p monad-cli -- help",
    "monad:version": "cargo run -p monad-cli -- version",
    "monad:info": "cargo run -p monad-cli -- info",
    "monad:check": "cargo run -p monad-cli -- check all",
    "monad:inspect": "cargo run -p monad-cli -- inspect workspace",
    "monad:graph": "cargo run -p monad-cli -- graph text",
    "monad:context": "cargo run -p monad-cli -- context help",
    "monad:memory": "cargo run -p monad-cli -- memory status"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@moonrepo/cli": "^2.2.5",
    "lefthook": "^1.13.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=24.18.0"
  }
}
